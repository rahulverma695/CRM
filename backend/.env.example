# --- Multi-tenancy / RLS note ---
# Tenant isolation is enforced by PostgreSQL Row-Level Security on every
# tenant-scoped table. PostgreSQL FORCE ROW LEVEL SECURITY is used, but on
# cloud Postgres (e.g. Neon) the default owner role typically has BYPASSRLS=true,
# which silently skips RLS enforcement even with FORCE.
#
# Two-role model:
#   - Runtime + tests connect as app_user (NOBYPASSRLS) — RLS IS enforced.
#   - Migrations connect as the owner/admin role (DDL, BYPASSRLS) — can see all rows.
#
# The app sets app.tenant_id per-transaction (see app/core/middleware/tenant_context.py)
# and policies enforce: tenant_id = current_setting('app.tenant_id')::uuid
#
# See scripts/provision_roles.sql for one-time role setup instructions.
# Do NOT run the app or tests with a BYPASSRLS role.
# ---------------------------------

# Runtime connects as a NOBYPASSRLS role (app_user) so RLS is enforced.
DATABASE_URL=postgresql+asyncpg://app_user:app_pass@host:5432/crmhr?ssl=require
# Tests connect as a NOBYPASSRLS role (app_user) so RLS is enforced.
TEST_DATABASE_URL=postgresql+asyncpg://app_user:app_pass@host:5432/crmhr_test?ssl=require
# Migrations connect as the owner/admin role for DDL.
MIGRATION_DATABASE_URL=postgresql+asyncpg://owner_user:owner_pass@host:5432/crmhr?ssl=require

JWT_SECRET=change-me-in-production
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=14
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback
FRONTEND_URL=http://localhost:5173
