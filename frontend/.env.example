# Base URL of the backend API.
# Local dev:  http://localhost:8000
# Production: https://<your-render-service>.onrender.com
VITE_API_URL=http://localhost:8000

# Optional: explicit WebSocket base URL. If unset, the client derives it from
# VITE_API_URL by swapping http(s)→ws(s). Only set this if your WS host differs.
# VITE_WS_URL=wss://<your-render-service>.onrender.com
